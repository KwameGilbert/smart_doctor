# Server Settings
PORT=6000
NODE_ENV=development

# Database Settings
# Replace with your local database URL: postgres://<username>:<password>@<host>:<port>/<database_name>
DATABASE_URL=postgres://postgres:postgres@localhost:5432/smart_doctor

# Authentication Settings
JWT_SECRET=super_secret_smart_doctor_key_123!
JWT_EXPIRES_IN=7d

# SMS Service Settings
# Supported Providers: TWILIO, TERMII, ARKESEL
SMS_PROVIDER=
# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
# Termii
TERMII_API_KEY=
TERMII_SENDER_ID=SmartDoc
# Arkesel
ARKESEL_API_KEY=
ARKESEL_SENDER_ID=SmartDoc

# Payment Settings
# Paystack Secret Key (e.g., sk_test_...). Set to "mock" or leave blank for local mock mode.
PAYSTACK_SECRET_KEY=mock

# Email SMTP Settings
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="Smart Doctor" <noreply@smartdoctor.com>

# Agora Video Call Settings
AGORA_APP_ID=
AGORA_APP_CERTIFICATE=
