### Smart Doctor Auth API Testing Configuration

@baseUrl = http://localhost:5000/v1

### 1. Health Check
GET {{baseUrl}}/health
Accept: application/json

###

### 2. Base Gateway Route
GET {{baseUrl}}/
Accept: application/json

###

### 3. Register a New Patient
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "email": "patient@example.com",
  "password": "SecurePassword123!",
  "firstName": "John",
  "lastName": "Doe",
  "phoneNumber": "+233240060001",
  "role": "PATIENT"
}

###

### 4. Register a New Doctor
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "email": "doctor@example.com",
  "password": "SecurePassword123!",
  "firstName": "Jane",
  "lastName": "Smith",
  "phoneNumber": "+233240004002",
  "role": "DOCTOR"
}

###

### 5. Verify Account OTP (For patient or doctor)
POST {{baseUrl}}/auth/verify
Content-Type: application/json

{
  "emailOrPhone": "patient@example.com",
  "code": "123456"
}

###

### 6. Resend Verification OTP
POST {{baseUrl}}/auth/resend-otp
Content-Type: application/json

{
  "emailOrPhone": "patient@example.com"
}

###

### 7. User Login
# @name login
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "dr.davis@smartdoctor.com",
  "password": "password123"
}

###

### 8. Forgot Password (Request reset OTP)
POST {{baseUrl}}/auth/forgot-password
Content-Type: application/json

{
  "email": "patient@example.com"
}

###

### 9. Reset Password using reset code
POST {{baseUrl}}/auth/reset-password
Content-Type: application/json

{
  "email": "patient@example.com",
  "code": "123456",
  "newPassword": "BrandNewSecurePassword123!"
}

###

###########################################################
# PROFILE & USER MANAGEMENT ENDPOINTS
###########################################################

### Fill in the Bearer token after logging in:
@authToken = eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

### 10. Get Logged-In User Profile
GET {{baseUrl}}/users/profile
Authorization: Bearer {{authToken}}
Accept: application/json

###

### 11. Update Logged-In Patient Profile
PUT {{baseUrl}}/users/profile
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "firstName": "Johnathan",
  "lastName": "Doel",
  "phoneNumber": "+233240060001",
  "dob": "1991-06-20",
  "gender": "Male",
  "bloodGroup": "O+",
  "allergies": "Penicillin, Aspirin",
  "emergencyContactName": "Jane Doe",
  "emergencyContactPhone": "+233240000004"
}

###

### 12. Update Logged-In Doctor Profile
PUT {{baseUrl}}/users/profile
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "firstName": "Sarah-Jane",
  "bio": "Consultant Cardiologist and Professor of Medicine.",
  "consultationFee": 150.00,
  "experienceYears": 16
}

###

### 13. Admin: List All Users
GET {{baseUrl}}/users
Authorization: Bearer {{authToken}}
Accept: application/json

###

### 14. Admin: List Only Doctors
GET {{baseUrl}}/users?role=DOCTOR
Authorization: Bearer {{authToken}}
Accept: application/json

###

### 15. Admin: Get Specific User Profile by ID
@targetUserId = b2c0c222-d24f-4e33-acbe-9e01d227361b
GET {{baseUrl}}/users/{{targetUserId}}
Authorization: Bearer {{authToken}}
Accept: application/json

###

### 16. Admin: Update Specific User Profile by ID (Override)
PUT {{baseUrl}}/users/{{targetUserId}}
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "firstName": "Sarah Updated",
  "bio": "Updated bio by admin override.",
  "consultationFee": 160.00,
  "experienceYears": 17,
  "status": "APPROVED"
}

###

### 17. Admin: Update Doctor Verification Status
PATCH {{baseUrl}}/users/doctors/{{targetUserId}}/status
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "status": "APPROVED"
}

###

### 18. Admin: Delete User by ID
# @targetDeleteUserId = <uuid>
# DELETE {{baseUrl}}/users/{{targetDeleteUserId}}
# Authorization: Bearer {{authToken}}

###

###########################################################
# DEDICATED ADMIN MANAGEMENT ENDPOINTS
###########################################################

### 19. Admin Panel: List All Patients
GET {{baseUrl}}/admin/patients
Authorization: Bearer {{authToken}}
Accept: application/json

###

### 20. Admin Panel: Update Specific Patient Details
@targetPatientId = c3d0d333-e34f-4f33-bcbe-0e01d227361c
PUT {{baseUrl}}/admin/patients/{{targetPatientId}}
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "firstName": "John Admin-Updated",
  "allergies": "Penicillin, Latex",
  "bloodGroup": "O-",
  "gender": "Male"
}

###

### 21. Admin Panel: List All Doctors
GET {{baseUrl}}/admin/doctors
Authorization: Bearer {{authToken}}
Accept: application/json

###

### 22. Admin Panel: Update Specific Doctor Details
@targetDoctorId = b2c0c222-d24f-4e33-acbe-9e01d227361b
PUT {{baseUrl}}/admin/doctors/{{targetDoctorId}}
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "firstName": "Sarah Admin-Updated",
  "bio": "Expert cardiovascular surgeon.",
  "consultationFee": 200.00,
  "experienceYears": 18
}

###

### 23. Admin Panel: Verify Doctor Status
PATCH {{baseUrl}}/admin/doctors/{{targetDoctorId}}/status
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "status": "APPROVED"
}

###

### 24. Admin Panel: Suspend User (Patient or Doctor)
# This sets users.isActive to false. Logging in as them will return 403.
PATCH {{baseUrl}}/admin/users/{{targetPatientId}}/suspend
Authorization: Bearer {{authToken}}
Accept: application/json

###

### 25. Admin Panel: Activate User (Patient or Doctor)
# This sets users.isActive to true.
PATCH {{baseUrl}}/admin/users/{{targetPatientId}}/activate
Authorization: Bearer {{authToken}}
Accept: application/json

###

### 26. Admin Panel: Delete User Profile (Admin Override)
# @targetDeleteId = <uuid>
# DELETE {{baseUrl}}/admin/users/{{targetDeleteId}}
# Authorization: Bearer {{authToken}}


